# Used by `railway up --no-gitignore` so we can bake gitignored
# artifacts/router-model without uploading .venv / checkpoint copies.
# Keep this lean — Railway rejects uploads over ~2GB.

.venv/
.git/
.github/
.pytest_cache/
.mypy_cache/
.ruff_cache/
__pycache__/
*.pyc
.env
.env.*
!.env.example

# Docs / tests / notebooks (not needed in the image build context)
docs/
tests/
*.ipynb
.DS_Store
*.bak

# Logs and prompt sidecars
logs/
artifacts/prompts/
artifacts/experiments/
artifacts/eval-results/
artifacts/judge_ab_cache/
artifacts/*.log

# Extra router checkpoints (keep only artifacts/router-model/)
artifacts/router-model-*/
artifacts/router-checkpoints/
artifacts/router-model-pre-rq1/
artifacts/router-model-rq1-run-a/
artifacts/router-model-rq1-run-b/

# Torch weights — ONNX path does not need these (~255MB each)
artifacts/router-model/model.safetensors
artifacts/router-model/training_args.bin

# model.onnx (~256MB) exceeds Railway `up` per-file upload limits (~250MB).
# Bake it via local `docker build` + registry push instead (see docs/DEPLOY.md).
# Do not remove this line unless you switch to an image-based deploy only.
artifacts/router-model/model.onnx
