# Groq API (generator, spec, test generator)
GROQ_API_KEY=your_groq_api_key_here

# NVIDIA API (LLM judge)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional model overrides
# ARCS_GENERATOR_MODEL=llama-3.3-70b-versatile
# ARCS_CODING_MODEL=
# ARCS_MEDICAL_MODEL=
# ARCS_LEGAL_MODEL=
# ARCS_GENERAL_MODEL=
# ARCS_SPEC_MODEL=qwen/qwen3-32b
# ARCS_TEST_GENERATOR_MODEL=qwen/qwen3-32b
# NVIDIA_JUDGE_MODEL=meta/llama-3.1-8b-instruct
# ARCS_CODING_MAX_RETRIES=3
# ARCS_ROUTER_CONFIDENCE=0.75
# ARCS_ROUTER_BACKEND=onnx
#   # Docker/production: onnx (after export_router_onnx.py); local dev may use torch

# Demo UI hardening (public deploy)
# ARCS_DEMO_PUBLIC=1
# ARCS_DEMO_RATE_LIMIT=8
# ARCS_DEMO_RATE_WINDOW=60
# ARCS_DEMO_FEEDBACK_RATE_LIMIT=30
# ARCS_DEMO_PIPELINE_TIMEOUT=180
# PORT=8000
# ARCS_DEMO_HOST=0.0.0.0
