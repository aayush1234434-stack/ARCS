# Local venv and caches
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets — never bake into images
.env
.env.local

# Runtime / generated (mount as volumes in compose)
artifacts/
# Allow router checkpoint in image builds (needed for Railway/Render bake).
# Keep torch weights out of the image when using ONNX (~255MB savings).
!artifacts/router-model/
!artifacts/router-model/**
artifacts/router-model/model.safetensors
artifacts/router-model/training_args.bin
logs/

# Git and editor
.git/
.gitignore
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Docs and notebooks (not needed at runtime)
docs/
*.ipynb
Untitled-1.ipynb

# Docker build context noise
Dockerfile
docker-compose.yml
.dockerignore
